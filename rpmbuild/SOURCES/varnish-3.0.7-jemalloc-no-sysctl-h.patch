Remove unused <sys/sysctl.h> include from bundled jemalloc.

The header was removed from glibc >= 2.32 (RHEL 9 ships glibc 2.34) and
nothing in jemalloc_linux.c actually uses sysctl(2) on Linux -- the
include is a leftover from the FreeBSD origin of the file.

--- varnish-3.0.7/lib/libjemalloc/jemalloc_linux.c.orig
+++ varnish-3.0.7/lib/libjemalloc/jemalloc_linux.c
@@ -177,7 +177,6 @@
 #include <sys/param.h>
 #include <sys/time.h>
 #include <sys/types.h>
-#include <sys/sysctl.h>
 #include <sys/uio.h>

 #include <errno.h>
